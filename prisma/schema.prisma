// 4Syte — Supplier Registration & B-BBEE Validation Platform
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPPLIER
  ADMIN
}

enum SupplierStatus {
  DRAFT
  SUBMITTED_PENDING_BEE
  BEE_INVALID_AWAITING_REUPLOAD
  BEE_VALID
  ONBOARDING
  ONBOARDED
  REJECTED
}

enum DocumentType {
  COI
  VAT_CERT
  TAX_CLEARANCE
  BBBEE
  BANK_PROOF
  AFFIDAVIT
  OTHER
}

enum DocumentStatus {
  UPLOADED
  VALIDATING
  VALID
  INVALID
  SUPERSEDED
}

enum ValidationResult {
  VALID
  INVALID
  INDETERMINATE
}

enum OnboardingState {
  INITIATED
  L1_PENDING
  L1_APPROVED
  L2_PENDING
  L2_APPROVED
  VETTING
  VETTING_PASSED
  SENDING_TO_ERP
  COMPLETE
  REJECTED
}

enum AffidavitDraftStatus {
  GENERATED
  VIEWED
  DOWNLOADED
  COMMISSIONED
  REUPLOADED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETE
  FAILED
}

enum CompanyType {
  PRIVATE_COMPANY
  CLOSE_CORPORATION
  SOLE_PROPRIETOR
  PUBLIC_COMPANY
  TRUST
  PARTNERSHIP
  NGO
  OTHER
}

enum BBBEEClassification {
  EME
  QSE
  GENERIC
}

enum BBBEESector {
  GENERIC
  ICT
  CONSTRUCTION
  TOURISM
  AGRI_BEE
  CHARTERED_ACCOUNTANCY
  FINANCIAL_SERVICES
  TRANSPORT
  MARKETING
  PROPERTY
  FORESTRY
}

enum ShareholderType {
  INDIVIDUAL
  COMPANY
}

enum ContactType {
  PRIMARY
  SECONDARY
}

enum AccountType {
  CURRENT
  SAVINGS
  TRANSMISSION
}

enum AgreementType {
  TERMS_AND_CONDITIONS
  PRIVACY_POLICY
  SUPPLIER_CODE_OF_CONDUCT
  DATA_PROCESSING
}

// ─── Core Auth ────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          Role      @default(SUPPLIER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  supplier             Supplier?
  verificationTokens   EmailVerificationToken[]
  passwordResetTokens  PasswordResetToken[]
  sessions             Session[]
  auditLogsActed       AuditLog[]              @relation("AuditActor")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  success   Boolean
  ip        String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

// ─── Supplier Core ────────────────────────────────────────────────────────────

model Supplier {
  id                 String         @id @default(cuid())
  userId             String         @unique
  status             SupplierStatus @default(DRAFT)
  vendorNumber       String?
  cumulativeYtdSpend Decimal?       @db.Decimal(18, 2)
  currentStep        Int            @default(1)
  submittedAt        DateTime?
  deletedAt          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user             User               @relation(fields: [userId], references: [id])
  companyInfo      CompanyInfo?
  physicalAddress  PhysicalAddress?
  postalAddress    PostalAddress?
  contacts         Contact[]
  bbbeeInfo        BBBEEInfo?
  owners           Owner[]
  productOfferings ProductOffering[]
  productLines     ProductServiceLine[]
  bankInfo         BankInfo?
  documents        Document[]
  agreements       Agreement[]
  validationRuns   ValidationRun[]
  affidavitDrafts  AffidavitDraft[]
  onboardingCase   OnboardingCase?
  auditLogs        AuditLog[]         @relation("AuditSubject")

  @@index([status])
  @@index([deletedAt])
}

// ─── Step 1: Company Information ─────────────────────────────────────────────

model CompanyInfo {
  id                    String      @id @default(cuid())
  supplierId            String      @unique
  // Submitter info (refs 1001–1006)
  submitterFullName     String      // ref 1001 max 40 chars
  submitterRole         String      // ref 1002 max 40 chars
  generalEmail          String      // ref 1003 — becomes username
  companyPhone          String      // ref 1004
  companyFax            String?     // ref 1005
  companyWebsite        String?     // ref 1006
  linkedIn              String?
  facebook              String?
  // Company registration (refs 1007–1011)
  registeredName        String      // ref 1007 max 40 chars
  companyType           CompanyType // ref 1008
  companyTypeOther      String?     // free text if OTHER
  tradingName           String?     // ref 1009
  registrationNumber    String      // ref 1010 — mask depends on 1008
  holdingCompanyName    String?     // ref 1011
  // Tax info (refs 1012–1016)
  vatRegistered         Boolean     // ref 1012
  vatNumber             String?     // ref 1013 — 9 digits, starts with 4
  taxClearancePin       String?     // ref 1014
  taxClearancePinExpiry DateTime?   // ref 1015
  vendorNumber          String?     // ref 1016 — set by integration only
  cumulativeYtdSpend    Decimal?    @db.Decimal(18, 2)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])
}

// ─── Step 2: Addresses & Contacts ────────────────────────────────────────────

model PhysicalAddress {
  id         String   @id @default(cuid())
  supplierId String   @unique
  street1    String   // ref 2001
  street2    String   // ref 2002
  city       String   // ref 2003
  country    String   // ref 2004
  province   String   // ref 2005
  postalCode String   // ref 2006 max 5 digits
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])
}

model PostalAddress {
  id             String   @id @default(cuid())
  supplierId     String   @unique
  sameAsPhysical Boolean  @default(false) // ref 2000
  street1        String   // ref 2007
  street2        String   // ref 2008
  city           String   // ref 2009
  country        String   // ref 2010
  province       String   // ref 2011
  postalCode     String   // ref 2012
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])
}

model Contact {
  id         String      @id @default(cuid())
  supplierId String
  type       ContactType
  fullName   String
  email      String
  phone      String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([supplierId, type])
}

// ─── Step 3: B-BBEE Info + Ownership ─────────────────────────────────────────

model BBBEEInfo {
  id                     String               @id @default(cuid())
  supplierId             String               @unique
  hasBBBEEDocument       Boolean              // ref 3000
  sector                 BBBEESector?         // ref 3001
  annualTurnoverBand     String?              // ref 3002
  classification         BBBEEClassification? // ref 3002a — computed
  blackOwnershipPct      Decimal?             @db.Decimal(5, 2) // ref 3003
  isBlackOwned           Boolean?             // ref 3004
  blackWomanOwnershipPct Decimal?             @db.Decimal(5, 2) // ref 3005
  isBlackWomanOwned      Boolean?             // ref 3006
  bdgPct                 Decimal?             @db.Decimal(5, 2)
  bdgYouthPct            Decimal?             @db.Decimal(5, 2)
  bdgDisabledPct         Decimal?             @db.Decimal(5, 2)
  bdgUnemployedPct       Decimal?             @db.Decimal(5, 2)
  bdgRuralPct            Decimal?             @db.Decimal(5, 2)
  bdgMilitaryVetPct      Decimal?             @db.Decimal(5, 2)
  bbbeeLevel             Int?                 // ref 3007 — 1–8
  modifiedFlowThrough    Boolean?             // ref 3008
  certExpiryDate         DateTime?            // ref 3009
  latestFinYearEnd       DateTime?            // ref 3010
  sanasAccreditedVA      String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])
}

model Owner {
  id                  String          @id @default(cuid())
  supplierId          String
  fullName            String          // ref 7001
  shareholderType     ShareholderType
  percentageOwnership Decimal         @db.Decimal(5, 2)
  idOrRegNumber       String
  positionInCompany   String
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
}

// ─── Step 4: Products + Bank ──────────────────────────────────────────────────

model ProductOffering {
  id                  String   @id @default(cuid())
  supplierId          String   @unique
  unspscCodes         String[]
  businessSummary     String   // ref 4001 max 1000 chars
  notifyOpportunities Boolean  @default(false) // ref 4005
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])
}

model ProductServiceLine {
  id          String   @id @default(cuid())
  supplierId  String
  name        String   // ref 4002 max 1000 chars
  description String?  // ref 4003
  region      String   // ref 4004
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
}

model BankInfo {
  id            String      @id @default(cuid())
  supplierId    String      @unique
  bankName      String
  accountType   AccountType
  branchName    String
  branchNumber  String
  swiftCode     String
  accountNumber String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])
}

// ─── Step 5: Documents & Agreements ──────────────────────────────────────────

model Document {
  id         String         @id @default(cuid())
  supplierId String
  type       DocumentType
  objectKey  String
  fileName   String
  mimeType   String
  sizeBytes  Int
  version    Int            @default(1)
  status     DocumentStatus @default(UPLOADED)
  uploadedAt DateTime       @default(now())
  deletedAt  DateTime?

  supplier       Supplier        @relation(fields: [supplierId], references: [id])
  validationRuns ValidationRun[]

  @@index([supplierId, type])
  @@index([status])
}

model Agreement {
  id         String        @id @default(cuid())
  supplierId String
  type       AgreementType
  version    String
  accepted   Boolean       @default(false)
  acceptedAt DateTime?
  createdAt  DateTime      @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([supplierId, type])
}

// ─── B-BBEE Validation Engine ─────────────────────────────────────────────────

model ValidationRule {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String
  sectorScope   String[]
  isBlocking    Boolean  @default(true)
  predicateMeta Json
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SanasAccreditedVA {
  id              String    @id @default(cuid())
  name            String    @unique
  accreditationNo String?
  validUntil      DateTime?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AffidavitTemplate {
  id             String               @id @default(cuid())
  sector         BBBEESector
  classification BBBEEClassification
  templateBody   String
  version        String
  active         Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([sector, classification, version])
}

model ValidationRun {
  id                  String           @id @default(cuid())
  supplierId          String
  documentId          String?
  engineVersion       String
  result              ValidationResult
  rulesFired          Json
  extractedFields     Json
  overallConfidence   Decimal?         @db.Decimal(4, 3)
  reasons             String[]
  adminOverride       Boolean          @default(false)
  adminOverrideBy     String?
  adminOverrideReason String?
  createdAt           DateTime         @default(now())

  supplier Supplier  @relation(fields: [supplierId], references: [id])
  document Document? @relation(fields: [documentId], references: [id])

  @@index([supplierId])
}

model AffidavitDraft {
  id            String               @id @default(cuid())
  supplierId    String
  templateId    String
  prefilledData Json
  pdfObjectKey  String?
  status        AffidavitDraftStatus @default(GENERATED)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
}

// ─── Onboarding ───────────────────────────────────────────────────────────────

model OnboardingCase {
  id              String          @id @default(cuid())
  supplierId      String          @unique
  state           OnboardingState @default(INITIATED)
  l1ApprovedBy    String?
  l1ApprovedAt    DateTime?
  l2ApprovedBy    String?
  l2ApprovedAt    DateTime?
  vettingResult   Json?
  erpVendorNumber String?
  auditTrail      Json            @default("[]")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])
}

// ─── Reference Data ───────────────────────────────────────────────────────────

model SectorTurnoverBand {
  id             String               @id @default(cuid())
  sector         BBBEESector
  label          String
  minTurnover    Decimal?             @db.Decimal(18, 2)
  maxTurnover    Decimal?             @db.Decimal(18, 2)
  classification BBBEEClassification
  sortOrder      Int

  @@index([sector])
}

model UnspscCode {
  id        String @id @default(cuid())
  code      String @unique
  title     String
  segment   String
  family    String
  classCode String
  commodity String
}

model Country {
  id       String    @id @default(cuid())
  code     String    @unique
  name     String
  dialCode String?

  provinces Province[]
}

model Province {
  id        String @id @default(cuid())
  countryId String
  code      String
  name      String

  country Country @relation(fields: [countryId], references: [id])

  @@unique([countryId, code])
}

model Bank {
  id        String  @id @default(cuid())
  name      String  @unique
  swiftCode String?
  active    Boolean @default(true)
}

// ─── Async Jobs ───────────────────────────────────────────────────────────────

model Job {
  id          String    @id @default(cuid())
  type        String
  payload     Json
  status      JobStatus @default(PENDING)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  runAt       DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAt])
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  supplierId String?
  action     String
  entity     String
  entityId   String
  before     Json?
  after      Json?
  meta       Json?
  createdAt  DateTime @default(now())

  actor    User?     @relation("AuditActor", fields: [actorId], references: [id])
  supplier Supplier? @relation("AuditSubject", fields: [supplierId], references: [id])

  @@index([supplierId, createdAt])
  @@index([actorId])
  @@index([entity, entityId])
}
